TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_USER_ID=your_telegram_user_id_here
# GROUPS_JSON_PATH=/path/to/groups.json

# LLM parsing (Groq)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# Webhook settings (optional - defaults to polling mode)
BOT_MODE=polling  # "polling" or "webhook"
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your_random_secret_here

# Health HTTP (optional). Set to 80 in Docker/ONCE; leave unset locally unless you need /up
# HEALTH_HTTP_PORT=80
