# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Spliit Configuration
SPLIIT_BASE_URL=https://spliit.app
# The group ID from your Spliit group URL (e.g., https://spliit.app/groups/abc123)
SPLIIT_GROUP_ID=your_group_id_here

# Optional: Restrict bot to specific Telegram user IDs (comma-separated)
# Leave empty to allow all users
ALLOWED_USER_IDS=
